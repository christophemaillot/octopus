{
  "id": "octopus",
  "name": "Octopus",
  "description": "Bridge between Octopus desktop client and OpenClaw agents — SSE endpoint + hooks for streaming, tool progress, and usage",
  "contracts": {
    "tools": []
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "port": {
        "type": "integer",
        "description": "WebSocket port for hub connection",
        "default": 3701
      },
      "authToken": {
        "type": "string",
        "description": "Bearer token for hub authentication"
      }
    },
    "additionalProperties": false
  }
}
