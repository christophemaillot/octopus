{
  "id": "octopus",
  "name": "Octopus",
  "description": "Agent-side connector for Octopus Hub — bridges local OpenClaw agents to the central hub",
  "contracts": {
    "tools": []
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "hubUrl": {
        "type": "string",
        "description": "WebSocket URL of the Octopus Hub (e.g. wss://hub.chrm.fr:3700)",
        "default": "ws://hub.chrm.fr:3700"
      },
      "token": {
        "type": "string",
        "description": "Authentication token for the hub"
      },
      "reconnectDelay": {
        "type": "integer",
        "description": "Reconnect delay in ms",
        "default": 5000
      }
    },
    "additionalProperties": false
  }
}
